---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getProjectWithSkills } from '../lib/graph';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const activeProjects = allProjects.filter(p => p.data.status === 'InProgress');

// Resolve skills for active projects
const resolvedProjects = await Promise.all(
  activeProjects.map(async (p) => {
    const full = await getProjectWithSkills(p.id);
    return {
      ...p,
      skills: full ? full.skills.map(s => ({ name: s.data.name, level: s.data.level })) : []
    };
  })
);
---

<Layout title="Collaborer — Hub de Crédibilité">
	<main class="max-w-5xl mx-auto px-6 py-20 animate-content">
		<header class="mb-20 text-center">
			<h1 class="text-4xl font-bold tracking-tight text-slate-900 mb-4">
				Bâtir Ensemble
			</h1>
			<p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
				Je crois fermement que la collaboration technique est le meilleur accélérateur de croissance. Je recherche des partenaires, des pairs et des contributeurs passionnés par l'ingénierie rigoureuse.
			</p>
		</header>

		<section class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-24">
			<!-- Collaboration Philosophy -->
			<div class="lg:col-span-1 space-y-8">
				<div class="p-6 rounded-2xl bg-slate-900 text-white shadow-xl">
					<h3 class="text-sm font-bold uppercase tracking-widest text-indigo-400 mb-4">Ma philosophie</h3>
					<ul class="space-y-4 text-sm leading-relaxed text-slate-300">
						<li class="flex gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
							</svg>
							<span><strong class="text-white">Proof-Driven :</strong> Je valorise les contributions basées sur des preuves concrètes et du code fonctionnel.</span>
						</li>
						<li class="flex gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
							</svg>
							<span><strong class="text-white">Asynchrone :</strong> Communication claire, documentée et respectueuse du temps de chacun.</span>
						</li>
						<li class="flex gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
							</svg>
							<span><strong class="text-white">Rigueur :</strong> Engagement total sur la qualité architecturale et la maintenabilité.</span>
						</li>
					</ul>
				</div>
			</div>

			<!-- Current Opportunities -->
			<div class="lg:col-span-2">
				<div class="flex items-center gap-4 mb-8">
					<h2 class="text-2xl font-bold text-slate-900">Projets Ouverts</h2>
					<span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest text-emerald-600 bg-emerald-50 border border-emerald-100 rounded">Actifs</span>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					{resolvedProjects.length > 0 ? (
						resolvedProjects.map(project => (
							<ProjectCard
								title={project.data.title}
								context={project.data.context}
								problem={project.data.problem_statement}
								solution={project.data.solution_description}
								role={project.data.role}
								status={project.data.status}
								featured={true}
								skills={project.skills}
								proofs={project.data.proofs}
							/>
						))
					) : (
						<div class="col-span-full p-12 border-2 border-dashed border-slate-200 rounded-2xl text-center">
							<p class="text-slate-400 italic">Aucune opportunité de collaboration active pour le moment. Restez connecté !</p>
						</div>
					)}
				</div>
			</div>
		</section>

		<section class="max-w-2xl mx-auto text-center py-12 bg-slate-50 rounded-3xl border border-slate-100">
			<h2 class="text-2xl font-bold text-slate-900 mb-4">Prêt à contribuer ?</h2>
			<p class="text-slate-600 mb-8 leading-relaxed">
				Si vous avez une idée, une compétence complémentaire ou si l'un des projets ci-dessus vous stimule, envoyez-moi un message détaillé.
			</p>
			<a href="/contact" class="inline-flex items-center px-8 py-3 bg-indigo-600 text-white rounded-full font-semibold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 active:scale-95">
				Envoyer une proposition
				<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
				</svg>
			</a>
		</section>
	</main>
</Layout>
