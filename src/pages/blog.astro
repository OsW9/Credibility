---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('blog');
const sortedArticles = articles.sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime());
---

<Layout title="Expériences & Réflexions — Sankofa Arch">
	<main class="max-w-4xl mx-auto px-6 py-20 animate-content">
		<header class="mb-16 text-center">
			<h1 class="text-4xl font-bold tracking-tight text-slate-900 mb-4">
				Réflexions & Retours d'Expérience
			</h1>
			<p class="text-lg text-slate-600 max-w-2xl mx-auto">
				Ici, je documente mon cheminement, mes erreurs et mes analyses techniques pour transformer l'expérience en savoir partageable.
			</p>
		</header>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{sortedArticles.map(article => (
				<article class="group relative p-6 rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md hover:border-indigo-200 transition-all duration-300 flex flex-col justify-between">
					<div>
						<div class="flex items-center gap-3 mb-4">
							<span class="text-[10px] font-bold uppercase tracking-widest text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded">
								{article.data.type}
							</span>
							<time class="text-xs text-slate-400">
								{article.data.published_at.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
							</time>
						</div>

						<h2 class="text-xl font-bold tracking-tight text-slate-900 group-hover:text-indigo-600 transition-colors mb-3">
							<a href={`/blog/${article.id}`}>
								{article.data.title}
							</a>
						</h2>
						
						<div class="flex flex-wrap gap-1.5 mb-6">
							{article.data.tags.map(tag => (
								<span class="text-[10px] text-slate-500 bg-slate-50 px-2 py-0.5 rounded border border-slate-100">
									#{tag}
								</span>
							))}
						</div>
					</div>

					<a href={`/blog/${article.id}`} class="text-xs font-semibold text-indigo-600 hover:text-indigo-800 inline-flex items-center gap-1 group-hover:translate-x-0.5 transition-transform">
						Lire la réflexion
						<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
						</svg>
					</a>
				</article>
			))}
		</div>
	</main>
</Layout>
