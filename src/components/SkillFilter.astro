---
interface Props {
  skills: Array<{ id: string, name: string, level: string }>;
}

const { skills } = Astro.props;
---

<div class="flex flex-wrap items-center gap-2 mb-10 justify-center">
  <span class="text-xs font-bold uppercase tracking-widest text-slate-400 mr-2">Filtrer par expertise:</span>
  <div class="flex flex-wrap gap-2">
    <button
      data-filter="all"
      class="filter-btn active px-3 py-1 rounded-full text-xs font-medium transition-all duration-200 border border-slate-200 bg-white text-slate-900 hover:border-indigo-500"
    >
      Tous les projets
    </button>
    {skills.map(skill => (
      <button
        data-filter={skill.id}
        class="filter-btn px-3 py-1 rounded-full text-xs font-medium transition-all duration-200 border border-slate-200 bg-white text-slate-600 hover:border-indigo-500 hover:text-indigo-600"
      >
        {skill.name}
      </button>
    ))}
  </div>
</div>

<script>
  function setupFilter() {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.project-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update buttons UI
        buttons.forEach(b => {
          b.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600', 'active');
          b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        });
        btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600', 'active');
        btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');

        const filter = btn.getAttribute('data-filter');

        cards.forEach(card => {
          const cardEl = card as HTMLElement;
          if (filter === 'all') {
            cardEl.style.display = 'block';
            cardEl.classList.add('animate-in', 'fade-in', 'duration-500');
          } else {
            const skills = cardEl.getAttribute('data-skills')?.split(',') || [];
            if (skills.includes(filter)) {
              cardEl.style.display = 'block';
              cardEl.classList.add('animate-in', 'fade-in', 'duration-500');
            } else {
              cardEl.style.display = 'none';
            }
          }
        });

        // Hide or show parent sections based on visible cards
        const sections = document.querySelectorAll('main > section');
        sections.forEach(section => {
          const sectionEl = section as HTMLElement;
          const sectionCards = sectionEl.querySelectorAll('.project-card');
          if (sectionCards.length > 0) {
            const hasVisible = Array.from(sectionCards).some(c => (c as HTMLElement).style.display !== 'none');
            sectionEl.style.display = hasVisible ? 'block' : 'none';
          }
        });
      });
    });
  }

  // Initial call
  setupFilter();
  // Re-run on view transitions if enabled
  document.addEventListener('astro:after-swap', setupFilter);
</script>

<style>
  @reference "tailwindcss";
  .filter-btn.active {
    @apply bg-indigo-600 text-white border-indigo-600;
  }
</style>
